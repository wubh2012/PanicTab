{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.1.0",
  "default_locale": "zh_CN",
  "description": "__MSG_appDescription__",
  "icons": {
    "16": "assets/panictab-shield-icon-16.png",
    "32": "assets/panictab-shield-icon-32.png",
    "48": "assets/panictab-shield-icon-48.png",
    "128": "assets/panictab-shield-icon-128.png"
  },
  "permissions": ["tabs", "tabGroups", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "assets/panictab-shield-icon-16.png",
      "32": "assets/panictab-shield-icon-32.png",
      "48": "assets/panictab-shield-icon-48.png",
      "128": "assets/panictab-shield-icon-128.png"
    }
  },
  "options_page": "src/options/options.html",
  "commands": {
    "panic-now": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "__MSG_commandPanicNowDescription__"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/error/page.html", "assets/default-bluescreen.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
